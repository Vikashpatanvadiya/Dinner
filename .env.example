# Copy this file to .env and fill in values for local development
# The .env file is gitignored — never commit real secrets

# ── Database (Neon) ────────────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details → Connection string
# Make sure to append ?sslmode=require to the URL
DATABASE_URL=postgresql://neondb_owner:your_password@ep-xxxx-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require
# ── API Server ─────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Auth ───────────────────────────────────────────────────────────────────
# Any long random string — used to sign JWTs
SESSION_SECRET=change-me-to-a-long-random-secret

# ── Frontend (only needed in Replit dev mode) ──────────────────────────────
# BASE_PATH=/
