# Copy to .env for local development

# Port for Vite dev server
PORT=5173

# Base path (leave as / unless deploying to a sub-path)
BASE_PATH=/

# Backend API URL — only needed in dev if not using the proxy default
# VITE_API_URL=http://localhost:3001

# In production (Vercel/Netlify), set this to your Render backend URL:
# VITE_API_URL=https://queue-manager-api.onrender.com
