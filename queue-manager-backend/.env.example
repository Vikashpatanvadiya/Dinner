# Copy to .env for local development — never commit .env

# Neon PostgreSQL connection string (direct connection, not pooled)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# HTTP port
PORT=5000

NODE_ENV=development

# JWT signing secret — any long random string
SESSION_SECRET=change-me-to-a-long-random-secret

# Frontend origin for CORS (use * in dev, set to your actual frontend URL in prod)
FRONTEND_URL=*
