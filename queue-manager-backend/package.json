{
  "name": "queue-manager-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node build.mjs && node --enable-source-maps ./dist/index.mjs",
    "build": "node build.mjs",
    "start": "node --enable-source-maps ./dist/index.mjs",
    "db:push": "drizzle-kit push --config ./lib/db/drizzle.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "esbuild": "^0.25.5",
    "esbuild-plugin-pino": "^2.3.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.22.0",
    "pino": "^9.14.0",
    "pino-http": "^10.5.0",
    "pino-pretty": "^13.1.3",
    "thread-stream": "3.1.0",
    "uuid": "^14.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "~5.9.3"
  }
}
